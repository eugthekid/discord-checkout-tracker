# -----------------------------------------------------------------------------
# Copy this file to ".env" (no ".example") and fill in the real values.
# The .env file is git-ignored so your secrets never get committed.
# -----------------------------------------------------------------------------

# Your bot's secret token, from the Discord Developer Portal
# (Applications -> your app -> Bot -> Reset Token). Treat it like a password.
DISCORD_TOKEN=paste-your-bot-token-here

# The channel where checkout webhooks are posted. To get it: in Discord, enable
# Developer Mode (Settings -> Advanced), then right-click the channel -> Copy Channel ID.
CHANNEL_ID=000000000000000000

# Your server's ID. Right-click the server icon -> Copy Server ID
# (Developer Mode must be on).
GUILD_ID=000000000000000000

# --- Optional overrides (fine to leave as-is) ---

# Text we look for to recognize a successful-checkout embed.
# SUCCESS_KEYWORD=Checked Out
